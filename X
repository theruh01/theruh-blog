  </main>

  <!-- ===== SIDEBAR ===== -->
  <aside class="sidebar">

    <!-- SEARCH -->
    <div class="widget">
      <div class="widget-head">⌕ Search</div>
      <div class="widget-body">
        <div class="search-wrap">
          <input type="text" class="search-inp" placeholder="Search posts..." id="searchInp">
          <button class="search-go" onclick="doSearch()">GO</button>
        </div>
      </div>
    </div>

    <!-- AUTHOR PROFILE -->
    <div class="widget" id="about-section">
      <div class="widget-head">✦ The Author</div>
      <div class="widget-body">
        <div class="author-photo">🌻</div>
        <div class="author-name">The Ruh</div>
        <div class="author-handle">theruh.write@gmail.com</div>
        <div class="author-bio">
          A wanderer with a pen. Writing about the unnamed streets, forgotten faces, and the quiet poetry hidden inside ordinary days. Based somewhere in India.
        </div>
        <div class="author-stats">
          <div>
            <span class="stat-num" id="postCount">0</span>
            <span class="stat-lbl">Posts</span>
          </div>
          <div>
            <span class="stat-num">0</span>
            <span class="stat-lbl">Readers</span>
          </div>
          <div>
            <span class="stat-num">0</span>
            <span class="stat-lbl">Reviews</span>
          </div>
        </div>
        <div class="author-socials">
          <a href="#" class="social-link">Instagram</a>
