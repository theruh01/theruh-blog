<!-- ===== MAIN LAYOUT ===== -->
<div class="layout">
  <main id="posts-area">

    <!-- EMPTY STATE — shows when no posts exist -->
    <div class="empty-state" id="emptyState">
      <span class="empty-envelope">✉</span>
      <div class="empty-title">No Dispatches Yet</div>
      <p class="empty-text">
        This journal is fresh. No ink has been spilled yet.<br><br>
        The author is sharpening the quill.<br>
        Come back soon — the first letter is being written.
      </p>
      <div class="empty-postmark">
        <svg viewBox="0 0 80 80">
          <circle cx="40" cy="40" r="37" stroke="#8b1a1a" stroke-width="1.2" fill="none" stroke-dasharray="3,3"/>
          <circle cx="40" cy="40" r="28" stroke="#8b1a1a" stroke-width="0.7" fill="none"/>
          <line x1="14" y1="40" x2="66" y2="40" stroke="#8b1a1a" stroke-width="1.4"/>
          <line x1="14" y1="35" x2="66" y2="35" stroke="#8b1a1a" stroke-width="0.5"/>
          <line x1="14" y1="45" x2="66" y2="45" stroke="#8b1a1a" stroke-width="0.5"/>
          <text x="40" y="26" text-anchor="middle" font-family="Courier New" font-size="5" fill="#8b1a1a" font-weight="bold">AWAITING</text>
          <text x="40" y="62" text-anchor="middle" font-family="Courier New" font-size="4.5" fill="#8b1a1a">FIRST POST</text>
        </svg>
      </div>
    </div>

    <!-- POSTS WILL APPEAR HERE when you write them via admin panel -->
