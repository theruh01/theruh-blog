<script>
// ===== READING PROGRESS BAR =====
window.addEventListener('scroll', () => {
  const bar = document.getElementById('readingBar');
  const scrolled = window.scrollY;
  const total = document.body.scrollHeight - window.innerHeight;
  bar.style.width = (scrolled / total * 100) + '%';
});

// ===== TOAST =====
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3200);
}

// ===== LIKE BUTTON =====
function toggleLike(btn) {
  const liked = btn.classList.toggle('liked');
  const parts = btn.textContent.split('(');
  const num = parseInt(parts[1]) || 0;
  btn.textContent = `♥ Like (${liked ? num + 1 : Math.max(0, num - 1)})`;
  if (liked) showToast('♥ Liked — noted in the journal');
}

// ===== COMMENT SUBMIT =====
function submitComment(formId, sectionId) {
  const form = document.getElementById(formId);
  const name = form.querySelector('.c-name').value.trim();
  const city = form.querySelector('.c-city').value.trim();
  const msg = form.querySelector('.c-msg').value.trim();
  if (!name || !msg) { showToast('✗ Please fill your name and message'); return; }

  const section = document.getElementById(sectionId);
  const noComments = section.querySelector('.no-comments');
  if (noComments) noComments.remove();

  const now = new Date();
  const dateStr = now.toLocaleDateString('en-IN', { day:'2-digit', month:'short', year:'numeric' }).toUpperCase();
  const timeStr = now.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit', hour12:false });

  const card = document.createElement('div');
  card.className = 'comment-card';
  card.innerHTML = `
    <div class="comment-header">
      <div class="comment-author-wrap">
        <div class="comment-avatar">${name[0].toUpperCase()}</div>
        <div>
          <div class="comment-name">${name}</div>
          <div class="comment-meta">From: ${city || 'Unknown City'} · ${dateStr}, ${timeStr}</div>
        </div>
      </div>
      <div class="comment-mini-stamp">
        <svg viewBox="0 0 42 42">
          <circle cx="21" cy="21" r="19" stroke="#8b1a1a" stroke-width="0.9" fill="none" stroke-dasharray="2,2"/>
          <line x1="7" y1="21" x2="35" y2="21" stroke="#8b1a1a" stroke-width="1.1"/>
          <line x1="7" y1="18" x2="35" y2="18" stroke="#8b1a1a" stroke-width="0.4"/>
          <line x1="7" y1="24" x2="35" y2="24" stroke="#8b1a1a" stroke-width="0.4"/>
          <text x="21" y="13" text-anchor="middle" font-family="Courier New" font-size="3" fill="#8b1a1a">READER</text>
          <text x="21" y="33" text-anchor="middle" font-family="Courier New" font-size="3" fill="#8b1a1a">INDIA</text>
        </svg>
      </div>
    </div>
    <div class="comment-body">"${msg}"</div>`;
  section.insertBefore(card, form.parentElement);

  form.querySelector('.c-name').value = '';
  form.querySelector('.c-city').value = '';
  form.querySelector('.c-msg').value = '';
  showToast('✉ Your letter has been posted!');
}

// ===== SUBSCRIBE =====
function subscribe() {
  const email = document.getElementById('nlEmail').value.trim();
  if (!email || !email.includes('@')) { showToast('✗ Please enter a valid email'); return; }
  showToast('✉ Subscribed! You will receive new posts.');
  document.getElementById('nlEmail').value = '';
}

// ===== CONTACT =====
function sendContact() {
  const name = document.getElementById('ctName').value.trim();
  const msg = document.getElementById('ctMsg').value.trim();
  if (!name || !msg) { showToast('✗ Please fill name and message'); return; }
  showToast('✉ Message sent to theRuh!');
  document.getElementById('ctName').value = '';
  document.getElementById('ctEmail').value = '';
  document.getElementById('ctMsg').value = '';
}

// ===== SEARCH =====
function doSearch() {
  const q = document.getElementById('searchInp').value.trim();
  if (!q) return;
  showToast('⌕ Searching for: ' + q);
}

// ===== SMOOTH SCROLL for nav links =====
document.querySelectorAll('a[href^="#"]').forEach(a => {
  a.addEventListener('click', e => {
    const target = document.querySelector(a.getAttribute('href'));
    if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
  });
});

// Count posts on load
function updatePostCount() {
  const count = document.querySelectorAll('.postcard').length;
  document.getElementById('postCount').textContent = count;
  if (count > 0) document.getElementById('emptyState').style.display = 'none';
}
updatePostCount();
</script>

</body>
