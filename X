    </div>

    <!-- CATEGORIES -->
    <div class="widget">
      <div class="widget-head">◉ Categories</div>
      <div class="widget-body">
        <ul class="cat-list">
          <li>Stranger Letters <span class="cat-count">0</span></li>
          <li>Photographs &amp; Film <span class="cat-count">0</span></li>
          <li>Video Dispatches <span class="cat-count">0</span></li>
          <li>Old City Walks <span class="cat-count">0</span></li>
          <li>Food &amp; Memory <span class="cat-count">0</span></li>
          <li>Personal <span class="cat-count">0</span></li>
        </ul>
      </div>
    </div>

    <!-- NEWSLETTER -->
    <div class="widget">
      <div class="widget-head">✉ Subscribe</div>
      <div class="widget-body">
        <div class="nl-text">New posts delivered to your inbox. No spam — just ink.</div>
        <div class="nl-wrap">
          <input type="email" class="f-input" id="nlEmail" placeholder="your@email.com">
          <button class="send-btn" style="width:100%" onclick="subscribe()">Subscribe ✦</button>
        </div>
      </div>
